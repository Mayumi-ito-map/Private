# コピーして `.env` にリネームし、値を埋めてください。
#   cp .env.example .env
# `.env` は Git に含めません。

# ---------------------------------------------------------------------------
# Google（Maps / Places / Geocoding など、プロジェクトで使うものに合わせる）
# ---------------------------------------------------------------------------
# 複数キーに分ける場合は名前を増やす（例: GOOGLE_MAPS_API_KEY）
GOOGLE_API_KEY=

# ---------------------------------------------------------------------------
# 世界遺産系 API（利用するサービスのドキュメントに合わせて変数名を調整）
# ---------------------------------------------------------------------------
WORLD_HERITAGE_API_KEY=

# ---------------------------------------------------------------------------
# 今後の追加用（例）
# ---------------------------------------------------------------------------
# OPENWEATHER_API_KEY=
# SOME_VENDOR_CLIENT_SECRET=
